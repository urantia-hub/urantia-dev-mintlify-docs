{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Urantia.dev",
  "colors": {
    "primary": "#2563EB",
    "light": "#3B82F6",
    "dark": "#1D4ED8"
  },
  "favicon": "/favicon.svg",
  "navigation": {
    "tabs": [
      {
        "tab": "Guides",
        "groups": [
          {
            "group": "Getting Started",
            "pages": ["index", "quickstart", "audio"]
          },
          {
            "group": "For AI Agents",
            "pages": ["ai-agents"]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "Overview",
            "pages": ["api-reference/introduction"]
          },
          {
            "group": "Table of Contents",
            "pages": ["api-reference/endpoint/get-toc"]
          },
          {
            "group": "Papers",
            "pages": [
              "api-reference/endpoint/list-papers",
              "api-reference/endpoint/get-paper",
              "api-reference/endpoint/get-paper-sections"
            ]
          },
          {
            "group": "Paragraphs",
            "pages": [
              "api-reference/endpoint/get-random-paragraph",
              "api-reference/endpoint/get-paragraph",
              "api-reference/endpoint/get-paragraph-context"
            ]
          },
          {
            "group": "Search",
            "pages": ["api-reference/endpoint/search"]
          },
          {
            "group": "Audio",
            "pages": ["api-reference/endpoint/get-audio"]
          }
        ]
      }
    ],
    "global": {
      "anchors": [
        {
          "anchor": "API",
          "href": "https://api.urantia.dev",
          "icon": "bolt"
        },
        {
          "anchor": "OpenAPI Spec",
          "href": "https://api.urantia.dev/openapi.json",
          "icon": "code"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/logo.svg",
    "dark": "/logo/logo.svg"
  },
  "api": {
    "baseUrl": "https://api.urantia.dev"
  },
  "openapi": "api-reference/openapi.json",
  "footer": {
    "socials": {
      "github": "https://github.com/kelsonic"
    }
  }
}
